    <string name="play_step_1_title">Roles Assigned</string>
    <string name="play_step_1_desc">Each round, roles are dealt in secret. Agents see the location. The Spy sees nothing.</string>
    <string name="play_step_2_title">Discussion Begins</string>
    <string name="play_step_2_desc">Players ask each other questions. Stay vague enough to hide, sharp enough to expose.</string>
    <string name="play_step_3_title">Call the Vote</string>
    <string name="play_step_3_desc">Any player can call a vote. The accused is eliminated and their role revealed.</string>
    <string name="play_step_4_title">The Spy\'s Move</string>
    <string name="play_step_4_desc">If hidden until time runs out — or if they correctly guess the location — the Spy wins.</string>
    <string name="play_step_5_title">Catch the Spy</string>
    <string name="play_step_5_desc">If the agents identify the Spy before the timer expires, the players take the round.</string>

    <string name="create_step_1_title">Set Your Nickname</string>
    <string name="create_step_1_desc">Choose how you appear to other operatives in the lobby.</string>
    <string name="create_step_2_title">Choose Settings</string>
    <string name="create_step_2_desc">Timer, win conditions and the word pack are all yours to define.</string>
    <string name="create_step_3_title">Share Code or QR</string>
    <string name="create_step_3_desc">Hand the 6-digit code or QR to your friends. They join over WiFi.</string>
    <string name="create_step_4_title">Wait for Players</string>
    <string name="create_step_4_desc">Watch operatives appear in the lobby. Minimum three to deploy.</string>
    <string name="create_step_5_title">Start the Game</string>
    <string name="create_step_5_desc">When the team is ready, drop the hammer and begin.</string>

