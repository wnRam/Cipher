    <!-- How to Play — Offline section -->
    <string name="how_to_section_offline">Offline Mode</string>
    <string name="offline_intro_title">One Phone, No Internet</string>
    <string name="offline_intro_desc">Offline Mode lets you play Cipher with a single device. No WiFi, no room codes — just pass the phone around.</string>
    <string name="offline_step_1_title">Set Up the Game</string>
    <string name="offline_step_1_desc">Choose how many players (3–10), pick a word pack, set the number of spies, and set the timer. No network needed.</string>
    <string name="offline_step_2_title">Roles Are Assigned</string>
    <string name="offline_step_2_desc">The app secretly assigns roles — Spy or Agent — to each player slot. You won\'t see them yet.</string>
    <string name="offline_step_3_title">Pass and Reveal</string>
    <string name="offline_step_3_desc">Pass the phone to Player 1. They tap the card to flip it and see their role privately, then tap Done. Repeat for every player.</string>
    <string name="offline_step_4_title">Start the Timer</string>
    <string name="offline_step_4_desc">Once everyone has seen their role, the host starts the timer. Discussion begins — Agents try to find the Spy, the Spy tries to blend in.</string>
    <string name="offline_step_5_title">No In-App Voting</string>
    <string name="offline_step_5_desc">Voting and accusations happen verbally. The phone holder can manually mark eliminated players on the game screen.</string>
    <string name="offline_step_6_title">Reveal the Location</string>
    <string name="offline_step_6_desc">At the end of the round, tap \'Reveal Location\' to confirm the secret location. Then play again or go back to the home screen.</string>

