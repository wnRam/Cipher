    <!-- How to Play — Offline section -->
    <string name="how_to_section_offline">Oflayn rejim</string>
    <string name="offline_intro_title">Bitta telefon, internetsiz</string>
    <string name="offline_intro_desc">Oflayn rejim Cipher\'ni bitta qurilmada o\'ynash imkonini beradi. WiFi va xona kodlarisiz — shunchaki telefonni uzating.</string>
    <string name="offline_step_1_title">O\'yinni sozlang</string>
    <string name="offline_step_1_desc">O\'yinchilar sonini (3–10), so\'zlar to\'plamini, josuslar sonini va taymerni tanlang. Tarmoq kerak emas.</string>
    <string name="offline_step_2_title">Rollar taqsimlandi</string>
    <string name="offline_step_2_desc">Ilova har bir o\'yinchiga yashirin tarzda rol — Josus yoki Agent — beradi. Siz ularni hali ko\'rmaysiz.</string>
    <string name="offline_step_3_title">Uzating va oching</string>
    <string name="offline_step_3_desc">Telefonni 1-o\'yinchiga uzating. U kartani bosib rolini ko\'radi, so\'ng «Tayyor» tugmasini bosadi. Har bir o\'yinchi uchun takrorlang.</string>
    <string name="offline_step_4_title">Taymerni ishga tushiring</string>
    <string name="offline_step_4_desc">Hamma rolini ko\'rgach, xost taymerni ishga tushiradi. Muhokama boshlanadi — Agentlar Josusni qidiradi, Josus yashirinmoqchi bo\'ladi.</string>
    <string name="offline_step_5_title">Ilovada ovoz berish yo\'q</string>
    <string name="offline_step_5_desc">Ovoz berish va ayblovlar og\'zaki bo\'ladi. Telefonni ushlab turgan kishi chiqarilgan o\'yinchilarni qo\'lda belgilashi mumkin.</string>
    <string name="offline_step_6_title">Joyni oching</string>
    <string name="offline_step_6_desc">Raund oxirida maxfiy joyni tasdiqlash uchun «Joyni ko\'rsatish» tugmasini bosing. So\'ng qayta o\'ynang yoki bosh sahifaga qayting.</string>

