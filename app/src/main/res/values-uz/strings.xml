    <string name="play_step_1_title">Rollar taqsimlandi</string>
    <string name="play_step_1_desc">Har raundda rollar yashirin tarqatiladi. Agentlar joyni biladi. Josus hech narsa ko\'rmaydi.</string>
    <string name="play_step_2_title">Muhokama boshlanadi</string>
    <string name="play_step_2_desc">O\'yinchilar bir-biriga savol beradi. Yashiringin, lekin bilishingizni ko\'rsating.</string>
    <string name="play_step_3_title">Ovoz berishni boshlang</string>
    <string name="play_step_3_desc">Har qanday o\'yinchi ovozni boshlashi mumkin. Ayblangan chiqariladi, roli ochiladi.</string>
    <string name="play_step_4_title">Josusning yo\'li</string>
    <string name="play_step_4_desc">Yashiringan yoki joyni topgan josus g\'alaba qozonadi.</string>
    <string name="play_step_5_title">Josusni toping</string>
    <string name="play_step_5_desc">Agar agentlar taymergacha josusni topsa — o\'yinchilar g\'olib.</string>

    <string name="create_step_1_title">Taxallus o\'rnating</string>
    <string name="create_step_1_desc">Lobbida qanday ko\'rinishni tanlang.</string>
    <string name="create_step_2_title">Sozlamalarni tanlang</string>
    <string name="create_step_2_desc">Taymer, shartlar va so\'zlar to\'plami siz uchun.</string>
    <string name="create_step_3_title">Kod yoki QR ulashish</string>
    <string name="create_step_3_desc">6 xonali kod yoki QR ni do\'stlarga bering. Ular WiFi orqali qo\'shiladi.</string>
    <string name="create_step_4_title">O\'yinchilarni kuting</string>
    <string name="create_step_4_desc">O\'yinchilar lobbida paydo bo\'ladi. Boshlash uchun kamida 3 ta.</string>
    <string name="create_step_5_title">O\'yinni boshlang</string>
    <string name="create_step_5_desc">Hamma tayyor bo\'lganda — boshlang.</string>

    <string name="join_step_1_title">Taxallus o\'rnating</string>
    <string name="join_step_1_desc">Operatsiyadan oldin chaqiruv tanlang.</string>
    <string name="join_step_2_title">Kod yoki QR</string>
    <string name="join_step_2_desc">6 xonali kodni kiriting yoki xost QR ni skanerlang.</string>
    <string name="join_step_3_title">Lobbida kuting</string>
    <string name="join_step_3_desc">Boshqa agentlar paydo bo\'ladi. Xost o\'yinni boshlaydi.</string>
    <string name="join_step_4_title">O\'yin avtomatik boshlanadi</string>
    <string name="join_step_4_desc">Xost raundni ishga tushirsa — siz o\'yindasiz.</string>

